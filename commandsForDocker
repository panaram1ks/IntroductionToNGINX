# 1. Собрать образ
docker build . -t nodeapp

# 2. Создать общую сеть
docker network create backendnet

# 3. Запустить три node-контейнера в одной сети
#    Порты на хосте разные (8081, 8082, 8083), внутри везде 8080
docker run --network backendnet --hostname nodeapp1 --name nodeapp1 -p 8081:8080 -d nodeapp
docker run --network backendnet --hostname nodeapp2 --name nodeapp2 -p 8082:8080 -d nodeapp
docker run --network backendnet --hostname nodeapp3 --name nodeapp3 -p 8083:8080 -d nodeapp

# 4. Запустить nginx в той же сети
docker run --network backendnet --hostname ng1 --name nginx -p 80:80 \
  -v $(pwd)/nginx.conf:/etc/nginx/nginx.conf \
  -d nginx

# 5. Запуск второй nginx в той же сети который распределяет теже nodeapp'ы
docker run --network backendnet --hostname ng2 --name nginx2 -p 81:80 \
  -v $(pwd)/nginx.conf:/etc/nginx/nginx.conf \
  -d nginx


docker inspect nginx
docker stop nginx

